# Copy to .env and adjust for local development (optional; defaults match docker-compose).

# Host ports — change these if the defaults collide with services already
# running on your machine (e.g. a local PostgreSQL on 5432).
POSTGRES_PORT=5432
RAG_PORT=8001

# PostgreSQL (matches docker-compose postgres service)
# If you changed POSTGRES_PORT above, update the Port value here to match.
ConnectionStrings__PostgreSQL=Host=localhost;Port=5432;Username=jobassistant;Password=jobassistant;Database=jobassistant

# Python RAG service (host reaches container-published port)
# If you changed RAG_PORT above, update the port in the URL to match.
Services__RagApiBaseUrl=http://localhost:8001
